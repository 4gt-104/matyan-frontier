FROM debian:bookworm-20260316-slim AS base

ARG IMAGE_VERSION=dev
LABEL org.opencontainers.image.title="matyan-frontier"
LABEL org.opencontainers.image.description="Ingestion gateway: WebSocket + presigned blob URLs, publishes to Kafka"
LABEL org.opencontainers.image.version="${IMAGE_VERSION}"
LABEL org.opencontainers.image.source="https://github.com/4gt-104/matyan-core"
LABEL org.opencontainers.image.documentation="https://4gt-104.github.io/matyan-core/"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Pixi provides Python 3.12 from conda-forge (see [tool.pixi.dependencies] in pyproject.toml).
ARG PIXI_VERSION=v0.66.0
ENV PATH="/root/.pixi/bin:${PATH}"

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/* \
    && curl -fsSL https://pixi.sh/install.sh | PIXI_VERSION=${PIXI_VERSION} bash

WORKDIR /app/matyan-frontier

COPY matyan-frontier/pyproject.toml matyan-frontier/pixi.lock ./

RUN pixi install -e dev --frozen --skip matyan-frontier --skip matyan-api-models

COPY matyan-api-models/ /app/matyan-api-models/
COPY matyan-frontier/src/ ./src/

RUN pixi install -e dev --frozen

ENV PATH="/app/matyan-frontier/.pixi/envs/dev/bin:${PATH}"

CMD ["matyan-frontier", "start", "--host", "0.0.0.0", "--port", "53801"]
