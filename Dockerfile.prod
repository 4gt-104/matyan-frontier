FROM python:3.12-slim AS base

ARG IMAGE_VERSION=0.2.0
LABEL org.opencontainers.image.title="matyan-frontier"
LABEL org.opencontainers.image.description="Ingestion gateway: WebSocket + presigned S3 URLs, publishes to Kafka"
LABEL org.opencontainers.image.version="${IMAGE_VERSION}"
LABEL org.opencontainers.image.source="https://github.com/4gt-104/matyan-core"
LABEL org.opencontainers.image.documentation="https://4gt-104.github.io/matyan-core/"
LABEL org.opencontainers.image.licenses="Apache-2.0"

COPY --from=ghcr.io/astral-sh/uv:0.10.3@sha256:7a88d4c4e6f44200575000638453a5a381db0ae31ad5c3a51b14f8687c9d93a3 /uv /uvx /bin/

WORKDIR /app

COPY pyproject.toml /app/matyan-frontier/
RUN cd /app/matyan-frontier && uv pip install --system --no-cache --no-sources -r pyproject.toml

COPY src/ /app/matyan-frontier/src/
RUN uv pip install --system --no-cache --no-deps /app/matyan-frontier/

CMD ["matyan-frontier", "start", "--host", "0.0.0.0", "--port", "53801"]
